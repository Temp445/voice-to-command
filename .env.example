# ============================================================
# ACE Voice Controller v1 — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- Backend ---
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=false


# --- Voice Pipeline ---
WAKE_WORD=alexa
WHISPER_MODEL=base
# Options: tiny, base, small, medium (more accurate, more RAM)

# --- TTS Engine ---
TTS_PROVIDER=piper
# Options: piper, gtts
GTTS_API_KEY=
# Required only if TTS_PROVIDER=gtts

# --- Piper TTS ---
PIPER_VOICE=en_US-lessac-medium
PIPER_MODELS_DIR=voice/tts/models

# --- Automation ---
BROWSER_TYPE=chromium
# Options: chromium, firefox, webkit

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=logs/ace.log
