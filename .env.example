# ============================================================
# ACE Voice Controller v1 — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- Backend ---
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
SECRET_KEY=your-secret-key
DEBUG=false


# --- Supabase ---
